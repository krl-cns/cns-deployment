# =============================================================================
# BrazenHalo — Environment Variables
# Brand:  BRAZENHALO
# VPS:    Dedicated (vps IP / hostname set in your internal docs)
# Dokploy app name: brazenhalo-erp
# Compose file:     brands/brazenhalo/docker-compose.yml
#
# ✅ Commit this file.  🚫 Never commit a file with real secret values.
#
# VARIABLE CLASSES:
#   [SECRET]  → Set in Dokploy Environment tab. Mark as secret. Never commit.
#   [CONFIG]  → Safe to commit. Defaults shown are production-appropriate.
#   [BUILD]   → Docker build args — set in Dokploy Build tab.
#   [ENV]     → Change per environment or brand.
#   [TOGGLE]  → One-shot operation triggers. Set 1 to run, then back to 0.
# =============================================================================

# =============================================================================
# IMAGE
# [ENV]
# =============================================================================
IMAGE_NAME=ghcr.io/kwaralabs/frappe-cns
IMAGE_TAG=latest
PULL_POLICY=always

# =============================================================================
# BUILD ARGUMENTS
# [BUILD]
# =============================================================================
FRAPPE_PATH=https://github.com/frappe/frappe
FRAPPE_BRANCH=version-16
PYTHON_VERSION=3.14
NODE_VERSION=24

# [SECRET] [BUILD]
APPS_JSON_BASE64=

# =============================================================================
# OPERATION TOGGLES
# [TOGGLE]
#
# FIRST DEPLOY — all set to 1.
# After first deploy completes, set CONFIGURE, REGENERATE_APPS_TXT,
# CREATE_SITE and MIGRATE back to 0. Keep ENABLE_DB=1 permanently.
# =============================================================================
ENABLE_DB=1
CONFIGURE=1
REGENERATE_APPS_TXT=1
CREATE_SITE=1
MIGRATE=1

# =============================================================================
# SITE
# [ENV]
# =============================================================================
SITE_NAME=erp.brazenhalo.com
FRAPPE_SITE_NAME_HEADER=
INSTALL_APP_ARGS=--install-app erpnext --install-app hrms --install-app crm

# =============================================================================
# DATABASE — MariaDB 11.8
# [SECRET] Never commit real passwords below.
# =============================================================================
DB_HOST=db
DB_PORT=3306

# [SECRET] — replace with your actual passwords before pasting into Dokploy
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# =============================================================================
# MARIADB TUNING
# [CONFIG]
# =============================================================================
MARIADB_INNODB_BUFFER_POOL_SIZE=2G
MARIADB_MAX_CONNECTIONS=200

# =============================================================================
# REDIS SIZING
# [CONFIG]
# =============================================================================
REDIS_CACHE_MAXMEMORY=512mb
REDIS_QUEUE_MAXMEMORY=256mb
REDIS_SOCKETIO_MAXMEMORY=64mb

# =============================================================================
# FRONTEND / NGINX
# [CONFIG]
# =============================================================================
FRONTEND_PORT=8080
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=300
CLIENT_MAX_BODY_SIZE=100m

# =============================================================================
# SMTP / EMAIL
# [SECRET] Configure post-install via ERPNext → Email Account settings.
# =============================================================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# =============================================================================
# S3 FILE STORAGE
# [SECRET]
# =============================================================================
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# =============================================================================
# BACKUP
# [CONFIG]
# =============================================================================
BACKUP_RCLONE_REMOTE=s3-backups
BACKUP_REMOTE_PATH=cns-backups/brazenhalo
BACKUP_RETENTION_DAYS=30

# =============================================================================
# KEYCLOAK / SSO (future)
# [SECRET]
# =============================================================================
KEYCLOAK_CLIENT_ID=erp-brazenhalo
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM_URL=
